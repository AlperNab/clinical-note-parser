{
  "slug": "clinical-note-parser",
  "name": "Clinical Note Parser",
  "domain": "Medical / Healthcare Data",
  "target_user": "Domain operator, business owner, analyst, or team member who needs this workflow executed reliably.",
  "core_job": "Clinical notes → structured medical data",
  "deep_features": [
    "de-identification",
    "FHIR mapping",
    "ICD/RxNorm/SNOMED suggestions",
    "confidence evidence",
    "abnormal-value flags",
    "medication timeline",
    "EHR export"
  ],
  "input_schema": [
    {
      "key": "clinical_notes",
      "label": "Clinical notes",
      "type": "textarea",
      "required": true,
      "help": "Affects input: Clinical notes.",
      "affects": [
        "prompt",
        "workflow"
      ],
      "default": ""
    },
    {
      "key": "work_brief",
      "label": "Work brief / source text / URL / instructions",
      "type": "textarea",
      "required": true,
      "default": "",
      "help": "Paste the material, URL, description, or instruction needed for this project.",
      "affects": [
        "prompt",
        "workflow"
      ]
    }
  ],
  "customization_schema": [
    {
      "key": "execution_mode",
      "label": "Execution mode",
      "type": "select",
      "required": false,
      "options": [
        "Draft",
        "Production",
        "Audit / strict review",
        "JSON/API output"
      ],
      "default": "Production",
      "help": "Controls strictness, depth, and output format for this project workflow.",
      "affects": [
        "workflow",
        "validation",
        "export"
      ]
    },
    {
      "key": "specialty",
      "label": "specialty",
      "type": "select",
      "required": false,
      "help": "Affects customization: specialty.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "options": [
        "general",
        "ENT",
        "cardiology",
        "internal medicine",
        "pediatrics",
        "psychiatry",
        "custom"
      ],
      "default": "general"
    },
    {
      "key": "coding_system",
      "label": "coding system",
      "type": "text",
      "required": false,
      "help": "Affects customization: coding system.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "phi_mode",
      "label": "PHI mode",
      "type": "select",
      "required": false,
      "help": "Affects customization: PHI mode.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "options": [
        "cloud allowed",
        "redact sensitive fields",
        "local only"
      ],
      "default": "cloud allowed"
    },
    {
      "key": "local_only_mode",
      "label": "local-only mode",
      "type": "select",
      "required": false,
      "help": "Affects customization: local-only mode.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "evidence_threshold",
      "label": "evidence threshold",
      "type": "slider",
      "required": false,
      "help": "Affects customization: evidence threshold.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "min": 0,
      "max": 100,
      "default": 50
    },
    {
      "key": "patient_age_group",
      "label": "patient age group",
      "type": "text",
      "required": false,
      "help": "Affects customization: patient age group.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "output_schema",
      "label": "output schema",
      "type": "select",
      "required": false,
      "help": "Affects customization: output schema.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "output_format",
      "label": "output format",
      "type": "select",
      "required": false,
      "help": "Affects customization: output format.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "options": [
        "Markdown",
        "JSON",
        "CSV",
        "PDF",
        "DOCX",
        "XLSX"
      ],
      "default": "Markdown"
    },
    {
      "key": "language",
      "label": "language",
      "type": "select",
      "required": false,
      "help": "Affects customization: language.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "options": [
        "English",
        "Arabic",
        "Egyptian Arabic",
        "French",
        "German",
        "Spanish"
      ],
      "default": "English"
    },
    {
      "key": "privacy_mode",
      "label": "privacy mode",
      "type": "select",
      "required": false,
      "help": "Affects customization: privacy mode.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "options": [
        "cloud allowed",
        "local only",
        "redact sensitive data"
      ],
      "default": "cloud allowed"
    },
    {
      "key": "confidence_threshold",
      "label": "Confidence threshold",
      "type": "slider",
      "required": false,
      "min": 0,
      "max": 100,
      "default": 75,
      "help": "Items below this confidence are escalated to the human review queue.",
      "affects": [
        "validation",
        "workflow",
        "export"
      ]
    }
  ],
  "workflow_steps": [
    "Clinical notes",
    "structured medical data"
  ],
  "ui_panels": [
    "note input",
    "entity extraction board",
    "FHIR preview",
    "validation warnings",
    "coding review"
  ],
  "output_formats": [
    "FHIR JSON",
    "coding suggestions",
    "de-identified summary"
  ],
  "integrations": [
    "File upload",
    "REST API",
    "Export download",
    "Job history",
    "FHIR/EHR optional",
    "ICD/SNOMED/RxNorm optional"
  ],
  "guardrails": [
    "Show uncertainty and confidence",
    "Cite evidence from input when possible",
    "Human review required for legal, medical, financial, hiring, or security decisions",
    "Do not invent facts absent from input"
  ],
  "recommended_models": {
    "drafting": "fast cloud or local instruct model",
    "reasoning": "strong reasoning model",
    "private_documents": "local model via Ollama/LM Studio/vLLM",
    "vision_or_pdf": "vision-capable model when image pages are used"
  },
  "suite": "Medical & Research Suite",
  "implementation_status": "real_local_engine_registered",
  "analysis_modules": [
    "clinical_extract",
    "phi_scan",
    "coding_candidates"
  ],
  "output_sections": [
    "SOAP sections",
    "Problem/medication list",
    "PHI warnings",
    "Coding candidates"
  ],
  "field_validations": [
    {
      "field": "output_schema",
      "rule": "Validate output keys against requested schema and include missing-key warnings."
    },
    {
      "field": "language",
      "rule": "Preserve requested language in final deliverable unless source text requires bilingual output."
    }
  ],
  "scorecards": [
    "Correctness",
    "Security risk",
    "Maintainability",
    "Test coverage",
    "Deployment readiness"
  ],
  "automation_hooks": [
    {
      "name": "save_job_snapshot",
      "type": "internal",
      "description": "Persist inputs, customization, uploads, output, and usage for audit/history."
    },
    {
      "name": "export_pack",
      "type": "internal",
      "description": "Export Markdown, JSON, PDF, and DOCX from the completed job."
    },
    {
      "name": "human_review_queue",
      "type": "manual",
      "description": "Flag low-confidence, legal/medical/finance/security/compliance-sensitive items for human review."
    }
  ],
